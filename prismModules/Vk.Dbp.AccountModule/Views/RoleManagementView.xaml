<UserControl
    x:Class="Vk.Dbp.AccountModule.Views.RoleManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,10" Orientation="Horizontal">
            <TextBlock Text="角色管理" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource PrimaryTextBrush}" 
                       VerticalAlignment="Center"/>
            <hc:UniformSpacingPanel Spacing="10" Margin="20,0,0,0">
                <Button Content="刷新" Command="{Binding LoadCommand}" 
                        Style="{StaticResource ButtonPrimary}"/>
                <Button Content="新增角色" Command="{Binding AddRoleCommand}" 
                        Style="{StaticResource ButtonSuccess}"/>
                <Button Content="编辑角色" Command="{Binding EditRoleCommand}" 
                        CommandParameter="{Binding SelectedRole}"
                        Style="{StaticResource ButtonInfo}"/>
                <Button Content="删除角色" Command="{Binding DeleteRoleCommand}" 
                        CommandParameter="{Binding SelectedRole}"
                        Style="{StaticResource ButtonDanger}"/>
                <Button Content="分配权限" Command="{Binding AssignPermissionsCommand}" 
                        CommandParameter="{Binding SelectedRole}"
                        Style="{StaticResource ButtonWarning}"/>
            </hc:UniformSpacingPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <DataGrid ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0,1,0,1"
                      BorderBrush="{DynamicResource BorderBrush}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="角色名称" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                    <DataGridCheckBoxColumn Header="启用状态" Binding="{Binding IsEnabled}" Width="80"/>
                    <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedTime, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                    <DataGridTemplateColumn Header="操作" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <hc:UniformSpacingPanel Spacing="5">
                                    <Button Content="编辑" 
                                            Command="{Binding DataContext.EditRoleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ButtonSmallInfo}"/>
                                    <Button Content="删除" 
                                            Command="{Binding DataContext.DeleteRoleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ButtonSmallDanger}"/>
                                    <Button Content="权限" 
                                            Command="{Binding DataContext.AssignPermissionsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ButtonSmallWarning}"/>
                                </hc:UniformSpacingPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            
            <hc:LoadingCircle Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
