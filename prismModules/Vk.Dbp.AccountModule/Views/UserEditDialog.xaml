<UserControl
    x:Class="Vk.Dbp.AccountModule.Views.UserEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Width="450">
    <Border Background="{DynamicResource PrimaryBackgroundBrush}" CornerRadius="8" Padding="25"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{Binding DialogTitle}" FontSize="18" FontWeight="Bold" 
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding EditUser.Username, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNewUser}"
                         Padding="10,8" Margin="0,0,0,10"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="真实姓名" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Grid.Row="1" Grid.Column="1" 
                         Text="{Binding EditUser.RealName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8" Margin="0,0,0,10"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="邮箱" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Grid.Row="2" Grid.Column="1" 
                         Text="{Binding EditUser.Email, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8" Margin="0,0,0,10"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="电话" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Grid.Row="3" Grid.Column="1" 
                         Text="{Binding EditUser.Phone, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8" Margin="0,0,0,10"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="密码" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,0,10"
                           Visibility="{Binding IsNewUser, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox"
                             Padding="10,8" Margin="0,0,0,10"
                             Background="{DynamicResource SecondaryBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             Visibility="{Binding IsNewUser, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="备注" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Top" Margin="0,8,0,10"/>
                <TextBox Grid.Row="5" Grid.Column="1" 
                         Text="{Binding EditUser.Remarks, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8" Margin="0,0,0,10" Height="60" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource SecondaryBackgroundBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="启用" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <CheckBox Grid.Row="6" Grid.Column="1" 
                          IsChecked="{Binding EditUser.IsEnabled}"
                          VerticalAlignment="Center" Margin="0,0,0,10"/>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" 
                       TextWrapping="Wrap" Margin="0,0,0,15"
                       Visibility="{Binding ShowError, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="取消" Command="{Binding CancelCommand}"
                        Style="{StaticResource ButtonDefault}" Padding="20,10" Margin="0,0,10,0"/>
                <Button Content="保存" Command="{Binding SaveCommand}"
                        CommandParameter="{Binding ElementName=PasswordBox}"
                        Style="{StaticResource ButtonPrimary}" Padding="20,10"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
