<UserControl
    x:Class="Vk.Dbp.AccountModule.Views.AdminSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Vk.Dbp.AccountModule.Views"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding Text}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="20"/>
        <TabControl Grid.Row="1" Margin="20,0,20,20" Background="{DynamicResource PrimaryBackgroundBrush}">
            <TabItem Header="用户管理">
                <local:UserManagementView/>
            </TabItem>
            <TabItem Header="角色管理">
                <local:RoleManagementView/>
            </TabItem>
            <TabItem Header="权限管理">
                <local:PermissionManagementView/>
            </TabItem>
            <TabItem Header="审计日志">
                <local:AuditLogView/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
