<UserControl
    x:Class="Vk.Dbp.AccountModule.Views.OrganizationManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:models="clr-namespace:Vk.Dbp.AccountModule.Models"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <HierarchicalDataTemplate x:Key="OrganizationItemTemplate" DataType="{x:Type models:OrganizationUnitModel}">
            <StackPanel Orientation="Horizontal">
                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"
                      Fill="{DynamicResource PrimaryBrush}"
                      Width="16" Height="16" Stretch="Uniform" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Code, StringFormat='({0})'}" 
                           VerticalAlignment="Center" Margin="5,0,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,20,20,10" Orientation="Horizontal">
            <TextBlock Text="组织架构管理" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource PrimaryTextBrush}" 
                       VerticalAlignment="Center"/>
            <hc:UniformSpacingPanel Spacing="10" Margin="20,0,0,0">
                <Button Content="刷新" Command="{Binding LoadCommand}" 
                        Style="{StaticResource ButtonPrimary}"/>
                <Button Content="新增根组织" Command="{Binding AddRootOrganizationCommand}" 
                        Style="{StaticResource ButtonSuccess}"/>
                <Button Content="新增子组织" Command="{Binding AddChildOrganizationCommand}" 
                        Style="{StaticResource ButtonSuccess}"/>
                <Button Content="编辑组织" Command="{Binding EditOrganizationCommand}" 
                        Style="{StaticResource ButtonInfo}"/>
                <Button Content="删除组织" Command="{Binding DeleteOrganizationCommand}" 
                        Style="{StaticResource ButtonDanger}"/>
            </hc:UniformSpacingPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource RegionBrush}" 
                    CornerRadius="8" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="组织架构" FontSize="16" FontWeight="Bold" 
                               Margin="0,0,0,10" Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding OrganizationTree}"
                              ItemTemplate="{StaticResource OrganizationItemTemplate}"
                              SelectedItemChanged="TreeView_SelectedItemChanged">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Background="{DynamicResource RegionBrush}" 
                    CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="组织信息" FontSize="16" FontWeight="Bold" 
                               Margin="0,0,0,15" Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="组织名称：" 
                                   VerticalAlignment="Center" Margin="0,0,10,10"/>
                        <hc:TextBox Grid.Row="0" Grid.Column="1" 
                                    Text="{Binding NewOrgName, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Placeholder="请输入组织名称"
                                    Margin="0,0,20,10"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="组织编码：" 
                                   VerticalAlignment="Center" Margin="0,0,10,10"/>
                        <hc:TextBox Grid.Row="0" Grid.Column="3" 
                                    Text="{Binding NewOrgCode, UpdateSourceTrigger=PropertyChanged}"
                                    hc:InfoElement.Placeholder="请输入组织编码"
                                    Margin="0,0,0,10"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource SecondaryRegionBrush}" 
                                CornerRadius="5" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="组织成员" FontSize="14" FontWeight="Bold" 
                                           Margin="0,0,0,10" Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding OrganizationUsers}"
                                          SelectedItem="{Binding SelectedUser}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="*"/>
                                        <DataGridTextColumn Header="姓名" Binding="{Binding RealName}" Width="*"/>
                                        <DataGridTemplateColumn Header="操作" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="移除" 
                                                            Command="{Binding DataContext.RemoveUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource ButtonSmallDanger}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                            <Button Content="&lt;" Width="40" Height="40" Margin="0,5"
                                    Command="{Binding RemoveUserCommand}"
                                    IsEnabled="{Binding SelectedUser, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>
                            <Button Content="&gt;" Width="40" Height="40" Margin="0,5"
                                    Command="{Binding AddUserCommand}"
                                    IsEnabled="{Binding SelectedAvailableUser, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}"/>
                        </StackPanel>

                        <Border Grid.Column="2" Background="{DynamicResource SecondaryRegionBrush}" 
                                CornerRadius="5" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="可添加用户" FontSize="14" FontWeight="Bold" 
                                           Margin="0,0,0,10" Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding AvailableUsers}"
                                          SelectedItem="{Binding SelectedAvailableUser}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="*"/>
                                        <DataGridTextColumn Header="姓名" Binding="{Binding RealName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <hc:LoadingCircle Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         Grid.RowSpan="2"/>
    </Grid>
</UserControl>
