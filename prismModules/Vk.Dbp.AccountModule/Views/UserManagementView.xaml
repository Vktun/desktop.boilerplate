<UserControl
    x:Class="Vk.Dbp.AccountModule.Views.UserManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <StackPanel Margin="20">
            <TextBlock Text="用户管理" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,20"/>
            <Button Content="加载用户" Command="{Binding LoadCommand}" Margin="0,0,0,10"/>
            <DataGrid ItemsSource="{Binding Users}" Height="400"/>
        </StackPanel>
    </Grid>
</UserControl>
