<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 亮色主题颜色定义 -->

    <!-- 主要背景色 -->
    <Color x:Key="PrimaryBackgroundColor">#ffffff</Color>
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackgroundColor}"/>

    <!-- 次要背景色 -->
    <Color x:Key="SecondaryBackgroundColor">#f7fafc</Color>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackgroundColor}"/>

    <!-- 边框色 -->
    <Color x:Key="BorderColor">#e2e8f0</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- 主要文本色 -->
    <Color x:Key="PrimaryTextColor">#2d3748</Color>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>

    <!-- 次要文本色 -->
    <Color x:Key="SecondaryTextColor">#4a5568</Color>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>

    <!-- 强调色 -->
    <Color x:Key="AccentColor">#3182ce</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

    <!-- 悬停色 -->
    <Color x:Key="HoverColor">#edf2f7</Color>
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}"/>

    <!-- 成功色 -->
    <Color x:Key="SuccessColor">#48bb78</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

    <!-- 警告色 -->
    <Color x:Key="WarningColor">#ed8936</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>

    <!-- 错误色 -->
    <Color x:Key="ErrorColor">#f56565</Color>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>

</ResourceDictionary>