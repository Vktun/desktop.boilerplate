<UserControl x:Class="Dabp.WpfWindow.Layout.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Dabp.WpfWindow.Layout"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="1200">
    <Grid Background="{DynamicResource PrimaryBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        
        <!-- Logo 区域 -->
        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="10 5 0 0">
            <TextBlock Text="Dabp" FontSize="{StaticResource HeadFontSize}" FontWeight="Bold" 
                       Foreground="{DynamicResource PrimaryTextBrush}" />
            <TextBlock Text="desktop.boilerplate" FontSize="{StaticResource TextFontSize}" FontWeight="Bold" 
                       Foreground="{DynamicResource SecondaryTextBrush}" />
        </StackPanel>
        
        <!-- 导航菜单区域 -->
        <StackPanel Orientation="Horizontal" Margin="5 5 0 0" Grid.Column="1" >
            <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Command="{Binding NavigateCommand}" 
                         CommandParameter="Dashboard" Margin="5">驾驶舱</ToggleButton>
            <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Command="{Binding NavigateCommand}" 
                         CommandParameter="SelfCheck" Margin="5">自检</ToggleButton>
            <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Command="{Binding NavigateCommand}" 
                         CommandParameter="Production" Margin="5">生产信息</ToggleButton>
            <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Command="{Binding NavigateCommand}" 
                         CommandParameter="ProductionRecord" Margin="5">生产记录</ToggleButton>
            <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Command="{Binding NavigateCommand}" 
                         CommandParameter="AlarmRecord" Margin="5">报警记录</ToggleButton>
            <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Command="{Binding NavigateCommand}" 
                         CommandParameter="AuditRecord" Margin="5">审计追踪</ToggleButton>
        </StackPanel>
        
        <!-- 右侧工具栏区域 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5 5 10 5" Grid.Column="2" >
            
            <!-- 主题切换按钮 -->
            <Button x:Name="ThemeButton" Margin="5" Height="50" Width="80" ToolTip="点击切换主题"
                    Background="Transparent" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Vertical">
                            <TextBlock HorizontalAlignment="Center" FontSize="20" Margin="0 5 0 0">
                                <Run Text="☀️" Foreground="#FFD700" x:Name="SunIcon"/>
                                <Run Text="🌙" Foreground="#9370DB" x:Name="MoonIcon"/>
                            </TextBlock>
                            <TextBlock Text="主题" HorizontalAlignment="Center" 
                                      Foreground="{DynamicResource SecondaryTextBrush}" 
                                      FontSize="9" Margin="0 5 0 0" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
                <Button.ContextMenu>
                    <ContextMenu Background="{DynamicResource SecondaryBackgroundBrush}" 
                                 BorderBrush="{DynamicResource BorderBrush}">
                        <MenuItem Header="亮色主题" Command="{Binding ToggleThemeCommand}" 
                                 CommandParameter="Light" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <MenuItem Header="暗色主题" Command="{Binding ToggleThemeCommand}" 
                                 CommandParameter="Dark" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </ContextMenu>
                </Button.ContextMenu>
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:InvokeCommandAction Command="{Binding ToggleThemeCommand}" 
                                              CommandParameter="Light"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>
            
            <!-- 通知铃铛 -->
            <ToggleButton BorderThickness="0" IsChecked="True" Style="{StaticResource ToggleButtonCustom}" 
                         hc:StatusSwitchElement.HideUncheckedElement="True" Command="{Binding NotificationCommand}" >
                <hc:StatusSwitchElement.CheckedElement>
                    <hc:Badge Maximum="0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="40" 
                             Margin="10 5 15 5" Style="{DynamicResource BadgeDanger}">
                        <Button>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Image Source="pack://application:,,,/Asserts/Icon/alarm-normal.png"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </hc:Badge>
                </hc:StatusSwitchElement.CheckedElement>
                <hc:Badge Maximum="99" VerticalAlignment="Center" HorizontalAlignment="Center" Height="40" 
                         Margin="10 5 15 5" Style="{DynamicResource BadgeDanger}" >
                    <Button>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image Source="pack://application:,,,/Asserts/Icon/alarm-red.png"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </hc:Badge>
            </ToggleButton>

            <!-- 后台管理按钮 -->
            <Button Margin="10 8 10 5" Height="50" Width="42" Command="{Binding NavigateCommand}" 
                   CommandParameter="AdminSettingView" >
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/Asserts/Icon/admin.png" Height="20" />
                            <TextBlock Text="后台管理" HorizontalAlignment="Center" 
                                      Foreground="{DynamicResource SecondaryTextBrush}" 
                                      FontSize="9" Margin="0 8 0 0" />
                        </StackPanel>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            
            <!-- 账户下拉菜单 -->
            <ToggleButton x:Name="Tbtn_Account" Margin="10 8 10 5" Height="50" Width="42" >
                <ToggleButton.Template>
                    <ControlTemplate TargetType="ToggleButton">
                        <StackPanel Orientation="Vertical">
                            <Image Source="pack://application:,,,/Asserts/Icon/account.png" Height="25" />
                            <TextBlock HorizontalAlignment="Center" Text="{Binding UserName}" 
                                      Foreground="{DynamicResource SecondaryTextBrush}" 
                                      FontSize="9" Margin="0 8 0 0" />
                        </StackPanel>
                    </ControlTemplate>
                </ToggleButton.Template>
                <ToggleButton.Triggers>
                    <EventTrigger RoutedEvent="ToggleButton.Checked">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation 
                                    Storyboard.Target="{Binding ElementName=theTransform}"
                                    Storyboard.TargetName="theTransform"
                                    Storyboard.TargetProperty="(RotateTransform.Angle)" 
                                    From="0" To="0" Duration="0:0:15" AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </ToggleButton.Triggers>
                <Popup IsOpen="{Binding IsChecked, ElementName=Tbtn_Account}" 
                      PlacementTarget="{Binding ElementName=Tbtn_Account}"            
                      AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-180" 
                      VerticalOffset="5" StaysOpen="True" >
                    <Border Background="{DynamicResource PrimaryBackgroundBrush}" 
                           BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                           CornerRadius="12" Margin="5">
                        <StackPanel Width="220" Orientation="Vertical" Margin="10 12">
                            <StackPanel.RenderTransform>
                                <RotateTransform x:Name="theTransform" />
                            </StackPanel.RenderTransform>
                            <TextBlock Margin="0 0 0 4" Foreground="{DynamicResource PrimaryTextBrush}" 
                                      FontSize="18" FontWeight="SemiBold" Text="{Binding UserName}" />
                            <StackPanel Orientation="Horizontal" Margin="0 0 0 12">
                                <TextBlock Text="状态: " Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <TextBlock Text="{Binding UserStatus}" Foreground="{DynamicResource SuccessBrush}" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                            <hc:Divider Margin="0 0 0 8" LineStroke="{DynamicResource BorderBrush}"/>
                            <Button Content="修改密码" Margin="0 4 0 0" Padding="12 10" 
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                                   FontSize="14" Height="Auto" Background="{DynamicResource SecondaryBackgroundBrush}" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                   BorderBrush="Transparent" BorderThickness="0"
                                   Command="{Binding AccountCommand}" CommandParameter="ChangePassword"
                                   IsEnabled="{Binding IsLoggedIn}"/>
                            <Button Content="注销" Margin="0 4 0 0" Padding="12 10" 
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                                   FontSize="14" Height="Auto" Background="{DynamicResource SecondaryBackgroundBrush}" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                   BorderBrush="Transparent" BorderThickness="0"
                                   Command="{Binding AccountCommand}" CommandParameter="Logout"
                                   IsEnabled="{Binding IsLoggedIn}"/>
                            <Button Content="关机" Margin="0 4 0 0" Padding="12 10" 
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                                   FontSize="14" Height="Auto" Background="{DynamicResource SecondaryBackgroundBrush}" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                   BorderBrush="Transparent" BorderThickness="0"
                                   Command="{Binding AccountCommand}" CommandParameter="Shutdown"/>
                            <Button Content="关闭" Margin="0 4 0 0" Padding="12 10" 
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" 
                                   FontSize="14" Height="Auto" Background="{DynamicResource SecondaryBackgroundBrush}" 
                                   Foreground="{DynamicResource PrimaryTextBrush}" 
                                   BorderBrush="Transparent" BorderThickness="0"
                                   Command="{Binding AccountCommand}" CommandParameter="Close"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </ToggleButton>
          
        </StackPanel>
    </Grid>
</UserControl>

