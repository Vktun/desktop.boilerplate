<Window x:Class="Dabp.WpfWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Dabp.WpfWindow"
        mc:Ignorable="d"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="650" Width="1200">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CaptionHeight="30" NonClientFrameEdges="None"  CornerRadius="10" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#f0f4f8" Offset="0"></GradientStop>
                <GradientStop Color="#e2e8f0" Offset="1"></GradientStop>
            </LinearGradientBrush>
        </Grid.Background>
        <DockPanel LastChildFill="True">
            <ContentControl prism:RegionManager.RegionName="HeaderRegion" DockPanel.Dock="Top"  Margin="10 10 10 0"  />
            <Border BorderBrush="#e2e8f0" BorderThickness="0 1 0 0" Padding="10">
                <ContentControl prism:RegionManager.RegionName="ContentRegion" Margin="10"  />
            </Border>
        </DockPanel>
    </Grid>
</Window>
